function pullGacha() {
  let rng = Math.random() * 100;
  
  if (rng <= 2) {
    return "🌟 [5-STAR] Wah, dapet Waifu Wangy! Selamat!";
  } else if (rng <= 20) {
    return "🟦 [4-STAR] Lumayanlah buat bahan party.";
  } else {
    let trashPool = ["Trashcan 🗑️", "Mint 🌿", "Cabbage 🥬", "Potato 🥔"];
    let item = trashPool[Math.floor(Math.random() * trashPool.length)];
    return "⚪ [TRASH] Kamu dapet: " + item + ". (Bau sampah ya?)";
  }
}
